# Copy to .env (gitignored) and fill in. CI reads these from GitHub Secrets.

# Stage entry for the quiz. goTo(route) is relative to this.
BASE_URL=https://stage.allright.com

# Stage API base — used by the outcome oracle (apiClient) to verify user + booking.
# Request the real value + any creds from the Charlie team; leave blank to fall back to
# the network-response-intercept oracle instead of the API oracle.
API_URL=
API_TOKEN=

# Domain/tag used to build synthetic tagged leads via quizLead(prefix).
# ASSUMPTION: replace with the test domain the Charlie team designates for synthetic sign-ups.
QUIZ_EMAIL_DOMAIN=aqa.example.com
