{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["lib/*"],
      "@pages/*": ["lib/pages/*"],
      "@data/*": ["lib/data/*"],
      "@api/*": ["lib/api/*"],
      "@helpers/*": ["lib/helpers/*"],
      "@root/*": ["*"]
    }
  },
  "include": ["lib", "tests", "playwright.config.ts"],
  "exclude": ["node_modules"]
}
